{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./electron/dist",
    "rootDir": "./electron/src"
  },
  "include": ["electron/src/**/*"],
  "exclude": ["node_modules"]
}
